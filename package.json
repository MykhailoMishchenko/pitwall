{
  "name": "pitwall",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "concurrently -k -n web,api \"vite\" \"tsx watch server/api.ts\"",
    "web": "vite",
    "api": "tsx watch server/api.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/ingest-jolpica.ts && tsx scripts/ingest-fantasy.ts && tsx scripts/ingest-predict.ts",
    "ingest:jolpica": "tsx scripts/ingest-jolpica.ts",
    "ingest:fantasy": "tsx scripts/ingest-fantasy.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@tanstack/react-query": "^5.101.0",
    "hono": "^4.12.25",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
